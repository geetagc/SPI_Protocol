module s2c_spi_slave (
input wire sclk,
input wire [7:0] tx_data,
input wire cs,
input wire mosi,

output reg [7:0] rx_data,
output reg miso
);

reg [7:0] shift_tx;
reg [7:0] shift_rx;
reg [2:0] bit_cnt;

always @(negedge cs) begin
shift_tx <= tx_data;
shift_rx <= 0;
bit_cnt <= 3'd7;
end

always @(posedge cs) begin
rx_data <= shift_rx;
end

always @(posedge sclk) begin
if (!cs) begin
miso <= shift_tx[bit_cnt]; // send
shift_rx <= {shift_rx[6:0], mosi}; // receive
bit_cnt <= bit_cnt - 1;
end
end

endmodule


module s2c_spi_master (
input wire clk,
input wire reset,

input wire start,
input wire [7:0] tx_data,
output reg busy,
output reg [7:0] rx_data,

// SPI signals
output reg sclk,
output reg mosi,
input wire miso,
output reg cs
);

reg [7:0] shift_tx;
reg [7:0] shift_rx;
reg [2:0] bit_cnt;

always @(posedge clk or posedge reset) begin
if (reset) begin
sclk <= 0;
cs <= 1;
mosi <= 0;
busy <= 0;
shift_tx <= 0;
shift_rx <= 0;
bit_cnt <= 0;
rx_data <= 0;

end
else begin
if (start && !busy) begin
busy <= 1;
cs <= 0;
sclk <= 0;
shift_tx <= tx_data;
bit_cnt <= 3'd7;
end
else if (busy) begin

// Toggle clock
sclk <= ~sclk;

// rising edge → send data
if(sclk == 1'b0) begin
mosi <= shift_tx[7];
shift_tx <= {shift_tx[6:0], 1'b0};
end
else begin

// falling edge → sample data
shift_rx <= {shift_rx[6:0], miso};

if (bit_cnt == 0) begin
busy <= 0;
cs <= 1;
sclk <= 0;
rx_data <= {shift_rx[6:0], miso};
end
else begin
bit_cnt <= bit_cnt - 1;
end
end
end
end
end

endmodule


